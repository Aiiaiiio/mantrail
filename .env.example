# Get this from Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
# It looks like: 1234567890-abc123def456.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id-here

# A random string used to sign session tokens. Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret

# Optional: defaults to 23456
PORT=23456
